---
import MainGridLayout from "../layouts/MainGridLayout.astro";
---

<MainGridLayout title="作品集" description="我的项目和技能展示">
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full">
            <h1 class="text-2xl font-bold mb-4">作品集</h1>
            <p class="text-neutral-500 mb-6">这里展示我的项目和技能</p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="border border-black/10 dark:border-white/10 rounded-lg p-4">
                    <h3 class="font-bold mb-2">个人网站</h3>
                    <p class="text-sm text-neutral-500 mb-2">使用 Astro + Fuwari 模板搭建</p>
                    <div class="flex flex-wrap gap-2 mb-2">
                        <span class="text-xs px-2 py-0.5 rounded border border-black/10 dark:border-white/10">Astro</span>
                        <span class="text-xs px-2 py-0.5 rounded border border-black/10 dark:border-white/10">Tailwind CSS</span>
                        <span class="text-xs px-2 py-0.5 rounded border border-black/10 dark:border-white/10">Cloudflare Pages</span>
                    </div>
                    <a href="https://wmm-site.pages.dev" class="text-[var(--primary)] text-sm mt-2 inline-block">
                        查看项目 →
                    </a>
                </div>

                <div class="border border-black/10 dark:border-white/10 rounded-lg p-4">
                    <h3 class="font-bold mb-2">AI 学习工程</h3>
                    <p class="text-sm text-neutral-500 mb-2">AI 协同开发的学习记录和工具</p>
                    <div class="flex flex-wrap gap-2 mb-2">
                        <span class="text-xs px-2 py-0.5 rounded border border-black/10 dark:border-white/10">Claude Code</span>
                        <span class="text-xs px-2 py-0.5 rounded border border-black/10 dark:border-white/10">MCP</span>
                        <span class="text-xs px-2 py-0.5 rounded border border-black/10 dark:border-white/10">AI 协同</span>
                    </div>
                    <a href="https://github.com/WMM321" class="text-[var(--primary)] text-sm mt-2 inline-block">
                        查看 GitHub →
                    </a>
                </div>

                <div class="border border-black/10 dark:border-white/10 rounded-lg p-4">
                    <h3 class="font-bold mb-2">智能车项目</h3>
                    <p class="text-sm text-neutral-500 mb-2">2026 年智能车竞赛相关代码</p>
                    <div class="flex flex-wrap gap-2 mb-2">
                        <span class="text-xs px-2 py-0.5 rounded border border-black/10 dark:border-white/10">嵌入式</span>
                        <span class="text-xs px-2 py-0.5 rounded border border-black/10 dark:border-white/10">ROS</span>
                        <span class="text-xs px-2 py-0.5 rounded border border-black/10 dark:border-white/10">计算机视觉</span>
                    </div>
                    <a href="https://github.com/WMM321" class="text-[var(--primary)] text-sm mt-2 inline-block">
                        查看代码 →
                    </a>
                </div>

                <div class="border border-black/10 dark:border-white/10 rounded-lg p-4">
                    <h3 class="font-bold mb-2">Obsidian 知识库</h3>
                    <p class="text-sm text-neutral-500 mb-2">个人知识管理系统</p>
                    <div class="flex flex-wrap gap-2 mb-2">
                        <span class="text-xs px-2 py-0.5 rounded border border-black/10 dark:border-white/10">Obsidian</span>
                        <span class="text-xs px-2 py-0.5 rounded border border-black/10 dark:border-white/10">知识管理</span>
                        <span class="text-xs px-2 py-0.5 rounded border border-black/10 dark:border-white/10">学习笔记</span>
                    </div>
                    <a href="https://github.com/WMM321" class="text-[var(--primary)] text-sm mt-2 inline-block">
                        查看笔记 →
                    </a>
                </div>
            </div>
        </div>
    </div>
</MainGridLayout>
